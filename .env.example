# =========================================================================
# ReelFlow — variables de entorno (PLANTILLA).
# Copiá a .env.local y completá. NUNCA commitear .env.local.
# Infra 100% NUEVA: nada de AutoEnvía/LabelFlow se reutiliza.
# =========================================================================

# ---- Supabase (proyecto NUEVO) ----
# Públicas (las usa el browser):
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...ANON
# Secreta (SOLO worker / server-side, jamás en el browser):
SUPABASE_SERVICE_ROLE_KEY=ey...SERVICE_ROLE

# Buckets (prefijo reelflow_)
REELFLOW_UPLOADS_BUCKET=reelflow_uploads
REELFLOW_OUTPUTS_BUCKET=reelflow_outputs

# ---- Worker ----
REELFLOW_WORKER_POLL_MS=5000
REELFLOW_TIGHT_MARGIN=0.2s             # auto-editor --margin
REELFLOW_MAX_DURATION_SECONDS=600     # rechaza videos más largos (segundos)
REELFLOW_STALE_MINUTES=30             # reaper: jobs colgados -> error
# Concurrencia: no hay paralelismo in-process; se escala corriendo MÁS
# instancias del worker (el claim FOR UPDATE SKIP LOCKED lo soporta).

# ---- Whisper (local, whisper.cpp dentro de Docker) ----
REELFLOW_WHISPER_MODEL=medium       # tiny|base|small|medium|large-v3
REELFLOW_WHISPER_LANG=es

# ---- IA: copy del Reel (API de Anthropic — per-token, NO suscripción) ----
ANTHROPIC_API_KEY=sk-ant-...        # SECRETO, server-side
REELFLOW_AI_MODEL=claude-haiku-4-5-20251001   # barato para copy; subible a sonnet

# ---- Stripe (cobros globales) ----
STRIPE_SECRET_KEY=sk_test_...       # SECRETO
STRIPE_WEBHOOK_SECRET=whsec_...     # SECRETO
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
